<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fin-Z | Modern Banking Experience</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --glass: rgba(255, 255, 255, 0.8);
            --primary: #4FD1C5;
            --secondary: #F687B3;
            --accent: #63B3ED;
            --danger: #FC8181;
            --bg: #EDF2F7;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Lexend', sans-serif; }

        body {
            background: linear-gradient(135deg, #E2E8F0 0%, #BEE3F8 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        /* App Container */
        .app-shell {
            width: 100%;
            max-width: 420px;
            height: 850px;
            background: var(--glass);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 40px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
        }

        /* Top Navigation */
        .top-nav {
            padding: 30px 25px 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .user-profile { display: flex; align-items: center; gap: 10px; }
        .avatar { width: 45px; height: 45px; background: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; border: 3px solid white; }

        /* Balance Section */
        .balance-section {
            padding: 20px 25px;
            text-align: center;
        }
        .balance-title { font-size: 0.85rem; color: #718096; letter-spacing: 1px; text-transform: uppercase; }
        .balance-amount { font-size: 2.5rem; font-weight: 700; color: #2D3748; margin: 5px 0; }
        .budget-progress { height: 8px; background: #E2E8F0; border-radius: 10px; margin-top: 15px; overflow: hidden; }
        .progress-fill { height: 100%; background: var(--primary); transition: width 0.5s ease; }

        /* Quick Actions Card */
        .actions-card {
            background: white;
            margin: 10px 20px;
            padding: 20px;
            border-radius: 25px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.03);
        }

        .input-box { width: 100%; padding: 12px 15px; border: 2px solid #F7FAFC; background: #F7FAFC; border-radius: 15px; margin-bottom: 12px; outline: none; transition: 0.3s; font-size: 1rem; }
        .input-box:focus { border-color: var(--primary); background: white; }

        .btn-add {
            width: 100%;
            padding: 15px;
            background: #2D3748;
            color: white;
            border: none;
            border-radius: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }
        .btn-add:hover { transform: scale(1.02); background: #1A202C; }

        /* Stats Tab */
        .stats-container { height: 180px; padding: 10px; }

        /* Transaction List */
        .transaction-list {
            flex: 1;
            background: white;
            border-radius: 35px 35px 0 0;
            padding: 25px;
            overflow-y: auto;
            box-shadow: 0 -10px 30px rgba(0,0,0,0.02);
        }

        .item { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; animation: slideUp 0.4s ease forwards; }
        .item-icon { width: 45px; height: 45px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
        .item-meta { flex: 1; margin-left: 15px; }
        .item-meta b { display: block; font-size: 0.95rem; }
        .item-meta span { font-size: 0.75rem; color: #A0AEC0; }
        .item-price { font-weight: 700; color: var(--danger); }

        /* Meme Overlay */
        .overlay { display: none; position: absolute; inset: 0; background: rgba(0,0,0,0.8); z-index: 100; place-items: center; padding: 30px; }
        .meme-card { background: white; border-radius: 30px; padding: 25px; text-align: center; width: 100%; }
        .meme-card img { width: 100%; border-radius: 20px; margin-bottom: 15px; }

        @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

<div class="app-shell">
    <div class="top-nav">
        <div class="user-profile">
            <div class="avatar">HY</div>
            <div>
                <p style="font-size: 0.7rem; color: #718096;">Chào buổi sáng,</p>
                <b style="font-size: 0.9rem;">Hải Yến FDB</b>
            </div>
        </div>
        <button style="border:none; background:none; font-size: 1.2rem;">🔔</button>
    </div>

    <div class="balance-section">
        <p class="balance-title">Ngân sách còn lại</p>
        <div class="balance-amount" id="balance-val">2.000.000đ</div>
        <p style="font-size: 0.8rem; color: #718096;">Hạn mức tháng: <span id="limit-val">2.000.000</span>đ</p>
        <div class="budget-progress">
            <div class="progress-fill" id="progress-bar" style="width: 0%"></div>
        </div>
    </div>

    <div class="stats-container">
        <canvas id="mainChart"></canvas>
    </div>

    <div class="actions-card">
        <input type="number" id="amount" class="input-box" placeholder="Số tiền (VNĐ)...">
        <select id="category" class="input-box">
            <option value="Ăn uống" data-emoji="🍲">🍲 Ăn uống</option>
            <option value="Trà sữa" data-emoji="🧋">🧋 Trà sữa / Cafe</option>
            <option value="Di chuyển" data-emoji="🚌">🚌 Di chuyển</option>
            <option value="Học tập" data-emoji="📚">📚 Học tập</option>
        </select>
        <button class="btn-add" onclick="processPayment()">Ghi chép nhanh (3s)</button>
    </div>

    <div class="transaction-list" id="tx-list">
        <h4 style="margin-bottom: 15px; color: #4A5568;">Hoạt động gần đây</h4>
        </div>

    <div class="overlay" id="meme-screen" onclick="hideMeme()">
        <div class="meme-card">
            <img src="https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExOHJueXF6bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6JmVwPXYxX2ludGVybmFsX2dpZl9ieV9pZCZjdD1n/3o7TKVUn7iM8FMEU24/giphy.gif" alt="Meme Alert">
            <h2 style="color: var(--danger);">CHÁY TÚI RỒI YẾN ƠI!</h2>
            <p id="meme-msg" style="margin: 15px 0; color: #4A5568;"></p>
            <p style="font-size: 0.7rem; color: #A0AEC0;">(Bấm để quay lại tiết kiệm)</p>
        </div>
    </div>
</div>

<script>
    let limit = 2000000;
    let spent = 0;
    let history = JSON.parse(localStorage.getItem('finz_v2')) || [];
    let chart;

    function init() {
        renderList();
        renderChart();
        updateBalance();
    }

    function processPayment() {
        const amtInput = document.getElementById('amount');
        const catInput = document.getElementById('category');
        const amt = parseInt(amtInput.value);
        
        if(!amt || amt <= 0) return;

        const newTx = {
            id: Date.now(),
            amt: amt,
            cat: catInput.value,
            emoji: catInput.options[catInput.selectedIndex].dataset.emoji,
            date: "Hôm nay, " + new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})
        };

        history.unshift(newTx);
        localStorage.setItem('finz_v2', JSON.stringify(history));
        
        // Logic Meme "Sinh viên nghèo"
        if(catInput.value === "Trà sữa" && amt > 40000) {
            triggerMeme("Lại trà sữa? Một ly này bằng 3 gói mì tôm đấy Yến nhé! 😭");
        }

        amtInput.value = '';
        renderList();
        updateBalance();
        renderChart();
    }

    function updateBalance() {
        spent = history.reduce((sum, item) => sum + item.amt, 0);
        const remaining = limit - spent;
        const percent = (spent / limit) * 100;

        document.getElementById('balance-val').innerText = remaining.toLocaleString() + "đ";
        document.getElementById('progress-bar').style.width = Math.min(percent, 100) + "%";
        
        if(percent > 80) document.getElementById('progress-bar').style.background = "var(--danger)";
    }

    function renderList() {
        const container = document.getElementById('tx-list');
        const items = history.slice(0, 5); // Hiện 5 cái gần nhất
        
        let html = '<h4 style="margin-bottom: 15px; color: #4A5568;">Hoạt động gần đây</h4>';
        items.forEach(tx => {
            html += `
                <div class="item">
                    <div class="item-icon" style="background: #F7FAFC;">${tx.emoji}</div>
                    <div class="item-meta">
                        <b>${tx.cat}</b>
                        <span>${tx.date}</span>
                    </div>
                    <div class="item-price">-${tx.amt.toLocaleString()}đ</div>
                </div>
            `;
        });
        container.innerHTML = html;
    }

    function renderChart() {
        const stats = { "Ăn uống": 0, "Trà sữa": 0, "Di chuyển": 0, "Học tập": 0 };
        history.forEach(tx => stats[tx.cat] += tx.amt);

        const ctx = document.getElementById('mainChart').getContext('2d');
        if(chart) chart.destroy();
        
        chart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: Object.keys(stats),
                datasets: [{
                    label: 'Chi tiêu',
                    data: Object.values(stats),
                    borderColor: '#4FD1C5',
                    backgroundColor: 'rgba(79, 209, 197, 0.1)',
                    fill: true,
                    tension: 0.4,
                    borderWidth: 3,
                    pointRadius: 0
                }]
            },
            options: {
                plugins: { legend: { display: false } },
                scales: { y: { display: false }, x: { grid: { display: false } } },
                maintainAspectRatio: false
            }
        });
    }

    function triggerMeme(msg) {
        document.getElementById('meme-msg').innerText = msg;
        document.getElementById('meme-screen').style.display = 'grid';
    }

    function hideMeme() {
        document.getElementById('meme-screen').style.display = 'none';
    }

    init();
</script>

</body>
</html>
